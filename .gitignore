node_modules/
dist/
*.log

# Editor-local settings (the committed .vscode/mcp.json is the shared Hunch config).
.vscode/settings.json

# npm auth: references ${NPM_TOKEN} env var, but never commit in case a real token is pasted.
.npmrc

# Hunch: the SQLite index is a DERIVED artifact, rebuilt by `hunch index`.
# The JSON source of truth under .hunch/ IS committed.
.hunch/hunch.sqlite
.hunch/hunch.sqlite-*
.hunch/*.sqlite
.hunch/*.sqlite-journal
.hunch/*.sqlite-wal
.hunch/*.sqlite-shm
# Atomic-write temp files (normally consumed by rename; ignored in case one leaks).
.hunch/**/*.tmp*
