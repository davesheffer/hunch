{
  "name": "hunch-vscode",
  "displayName": "Hunch",
  "description": "Your repo's engineering memory, in the editor: see WHY code is the way it is (decisions, invariants, bug history), and capture what you decide — one command each.",
  "version": "0.17.1",
  "publisher": "davesheffer",
  "license": "MIT",
  "author": "Dave Sheffer <dave.sheffer1@gmail.com>",
  "icon": "media/icon.png",
  "homepage": "https://hunch-pi.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davesheffer/hunch.git",
    "directory": "vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/davesheffer/hunch/issues"
  },
  "galleryBanner": {
    "color": "#16150f",
    "theme": "dark"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "engineering-memory",
    "knowledge-graph",
    "code-intelligence",
    "decisions",
    "invariants"
  ],
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "SCM Providers",
    "Visualization"
  ],
  "activationEvents": [
    "workspaceContains:.hunch/**"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hunch.why",
        "title": "Why is this?",
        "category": "Hunch",
        "icon": "$(question)"
      },
      {
        "command": "hunch.capture",
        "title": "Capture…",
        "category": "Hunch",
        "icon": "$(lightbulb)"
      },
      {
        "command": "hunch.journey",
        "title": "Journey — watch your memory compound",
        "category": "Hunch",
        "icon": "$(graph-line)"
      },
      {
        "command": "hunch.search",
        "title": "Search memory",
        "category": "Hunch",
        "icon": "$(search)"
      },
      {
        "command": "hunch.whySymbol",
        "title": "Why is this symbol the way it is?",
        "category": "Hunch"
      },
      {
        "command": "hunch.reviewInTerminal",
        "title": "Review drafts in terminal",
        "category": "Hunch"
      },
      {
        "command": "hunch.memoryGraph",
        "title": "Memory graph (wiki)",
        "category": "Hunch",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "hunch.memory.refresh",
        "title": "Refresh memory timeline",
        "category": "Hunch",
        "icon": "$(refresh)"
      },
      {
        "command": "hunch.memory.sync",
        "title": "Sync memory now",
        "category": "Hunch",
        "icon": "$(sync)"
      },
      {
        "command": "hunch.memory.adopt",
        "title": "Adopt drafts as advisory memory",
        "category": "Hunch",
        "icon": "$(check-all)"
      },
      {
        "command": "hunch.memory.push",
        "title": "Push memory to remote (approve)",
        "category": "Hunch",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "hunch.memory.strictness",
        "title": "Strictness…",
        "category": "Hunch",
        "icon": "$(shield)"
      },
      {
        "command": "hunch.revertMove",
        "title": "Revert this memory move",
        "category": "Hunch",
        "icon": "$(discard)"
      },
      {
        "command": "hunch.openMove",
        "title": "Open memory move diff",
        "category": "Hunch"
      },
      {
        "command": "hunch.openPolicyCard",
        "title": "Open proof card",
        "category": "Hunch"
      },
      {
        "command": "hunch.openEscalation",
        "title": "Open escalation",
        "category": "Hunch"
      },
      {
        "command": "hunch.activatePolicy",
        "title": "Activate rule (your vouch)…",
        "category": "Hunch",
        "icon": "$(verified)"
      },
      {
        "command": "hunch.demotePolicy",
        "title": "Demote to advisory…",
        "category": "Hunch",
        "icon": "$(arrow-down)"
      },
      {
        "command": "hunch.withdrawPolicy",
        "title": "Withdraw to proposed…",
        "category": "Hunch",
        "icon": "$(debug-step-back)"
      },
      {
        "command": "hunch.retirePolicy",
        "title": "Retire rule permanently…",
        "category": "Hunch",
        "icon": "$(archive)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hunch",
          "title": "Hunch Memory",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "hunch": [
        {
          "id": "hunch.memory",
          "name": "Memory Timeline",
          "icon": "$(book)",
          "contextualTitle": "Hunch Memory"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "hunch.whySymbol",
          "when": "false"
        },
        {
          "command": "hunch.reviewInTerminal",
          "when": "false"
        },
        {
          "command": "hunch.openMove",
          "when": "false"
        },
        {
          "command": "hunch.revertMove",
          "when": "false"
        },
        {
          "command": "hunch.openPolicyCard",
          "when": "false"
        },
        {
          "command": "hunch.openEscalation",
          "when": "false"
        },
        {
          "command": "hunch.activatePolicy",
          "when": "false"
        },
        {
          "command": "hunch.demotePolicy",
          "when": "false"
        },
        {
          "command": "hunch.withdrawPolicy",
          "when": "false"
        },
        {
          "command": "hunch.retirePolicy",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "hunch.memory.strictness",
          "when": "view == hunch.memory",
          "group": "navigation@0"
        },
        {
          "command": "hunch.memory.sync",
          "when": "view == hunch.memory",
          "group": "navigation@1"
        },
        {
          "command": "hunch.memory.adopt",
          "when": "view == hunch.memory",
          "group": "navigation@2"
        },
        {
          "command": "hunch.memory.push",
          "when": "view == hunch.memory",
          "group": "navigation@3"
        },
        {
          "command": "hunch.memory.refresh",
          "when": "view == hunch.memory",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "hunch.revertMove",
          "when": "view == hunch.memory && viewItem == hunchMove",
          "group": "inline"
        },
        {
          "command": "hunch.activatePolicy",
          "when": "view == hunch.memory && viewItem == hunchPolicyProposed",
          "group": "inline"
        },
        {
          "command": "hunch.demotePolicy",
          "when": "view == hunch.memory && viewItem == hunchPolicyBlocking",
          "group": "inline"
        },
        {
          "command": "hunch.withdrawPolicy",
          "when": "view == hunch.memory && viewItem == hunchPolicyAdvisory",
          "group": "inline"
        },
        {
          "command": "hunch.retirePolicy",
          "when": "view == hunch.memory && viewItem == hunchPolicyAdvisory",
          "group": "context"
        },
        {
          "command": "hunch.retirePolicy",
          "when": "view == hunch.memory && viewItem == hunchPolicyProposed",
          "group": "context"
        },
        {
          "command": "hunch.retirePolicy",
          "when": "view == hunch.memory && viewItem == hunchPolicyBlocking",
          "group": "context"
        }
      ],
      "editor/title": [
        {
          "command": "hunch.why",
          "when": "resourceLangId =~ /typescript|javascript|typescriptreact|javascriptreact|python|go|rust/",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "hunch.why",
          "when": "resourceLangId =~ /typescript|javascript|typescriptreact|javascriptreact|python|go|rust/",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Hunch",
      "properties": {
        "hunch.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show how many invariants guard the active file in the status bar."
        },
        "hunch.hover.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Hunch bug history and fragility when hovering a symbol."
        },
        "hunch.cliPath": {
          "type": "string",
          "default": "hunch",
          "description": "Command used to invoke the Hunch CLI for capture (set an absolute path if `hunch` is not on PATH)."
        }
      }
    },
    "languageModelTools": [
      {
        "name": "hunch-vscode_why",
        "displayName": "Hunch: Why",
        "toolReferenceName": "hunchWhy",
        "canBeReferencedInPrompt": true,
        "icon": "$(question)",
        "userDescription": "Why a file or symbol is the way it is — decisions, invariants, bug history, and blast radius from the repo's Hunch engineering memory.",
        "modelDescription": "Returns the recorded engineering memory for a file path or symbol in this repository: invariants that MUST NOT break (with severity and rationale), near-invariants reached through the dependency blast radius, the decisions that shaped the code (including rejected alternatives), bug history with root causes, and direct dependents. Call BEFORE modifying or reviewing a file to avoid breaking intentional design. Input: a workspace-relative file path (e.g. src/auth/session.ts) or a symbol name.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "target": {
              "type": "string",
              "description": "Workspace-relative file path or symbol name."
            }
          },
          "required": [
            "target"
          ]
        },
        "tags": [
          "hunch",
          "engineering-memory",
          "architecture"
        ]
      },
      {
        "name": "hunch-vscode_context",
        "displayName": "Hunch: Context",
        "toolReferenceName": "hunchContext",
        "canBeReferencedInPrompt": true,
        "icon": "$(list-tree)",
        "userDescription": "The pre-edit brief for a file: everything Hunch knows that an edit could break, plus its fragile symbols.",
        "modelDescription": "Assembles the minimal relevant engineering-memory context before working on a file: invariants in scope, near-invariants, shaping decisions, bug history, blast radius, and the file's fragile symbols (bug count / churn / fan-in signal). Call FIRST when starting non-trivial work on a file in a repo with a .hunch/ directory. Input: a workspace-relative file path.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "target": {
              "type": "string",
              "description": "Workspace-relative file path."
            }
          },
          "required": [
            "target"
          ]
        },
        "tags": [
          "hunch",
          "engineering-memory",
          "context"
        ]
      },
      {
        "name": "hunch-vscode_query",
        "displayName": "Hunch: Query",
        "toolReferenceName": "hunchQuery",
        "canBeReferencedInPrompt": true,
        "icon": "$(search)",
        "userDescription": "Free-text search across the repo's recorded decisions, invariants, bugs, and components.",
        "modelDescription": "Free-text search over every record in the repository's Hunch engineering-memory graph (decisions, invariants/constraints, bugs, components). Use to answer 'was this decided before?', 'has this failed before?', or to find the record governing a topic. Returns ranked matches with ids and related files. Input: a search query.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "What to search the graph for."
            }
          },
          "required": [
            "query"
          ]
        },
        "tags": [
          "hunch",
          "engineering-memory",
          "search"
        ]
      }
    ],
    "walkthroughs": [
      {
        "id": "hunch.gettingStarted",
        "title": "Get started with Hunch",
        "description": "See why code is the way it is; capture what you decide.",
        "steps": [
          {
            "id": "why",
            "title": "Why is this the way it is?",
            "description": "One command (and hover, and the status bar) answers it: invariants, decisions, bug history, blast radius.",
            "media": {
              "markdown": "media/walkthrough/why.md"
            }
          },
          {
            "id": "record",
            "title": "Capture what you decide",
            "description": "Hunch: Capture… records a decision, invariant, or bug into the repo's memory.",
            "media": {
              "markdown": "media/walkthrough/record.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "clean": "node --input-type=commonjs -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.9.3"
  }
}
