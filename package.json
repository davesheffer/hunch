{
  "name": "@brain/cli",
  "version": "0.1.0",
  "description": "Engineering Memory OS — a persistent, git-native reasoning graph (the Project Brain) over a codebase, exposed to Claude Code via MCP.",
  "type": "module",
  "bin": {
    "brain": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "brain": "tsx src/cli/index.ts",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "12.9.0",
    "commander": "^15.0.0",
    "tree-sitter": "0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
